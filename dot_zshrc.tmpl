export LDFLAGS="-L/opt/homebrew/opt/sqlite/lib"
export CPPFLAGS="-I/opt/homebrew/opt/sqlite/include"

# nvm
# lazy-load 제어: ~/.zshenv 나 세션 시작 전에 세팅
# NVM_LAZY_LOAD=0 이면 즉시 로드, 기본값은 lazy-load
export NVM_DIR="$HOME/.nvm"
if [[ "${NVM_LAZY_LOAD:-1}" == "0" ]]; then
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
  [ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"
else
  __nvm_lazy_load() {
    [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
    [ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"
    unset -f nvm node npm npx pnpm yarn corepack __nvm_lazy_load
  }
  for cmd in nvm node npm npx pnpm yarn corepack; do
    eval "$cmd() { __nvm_lazy_load; $cmd \"\$@\"; }"
  done
fi

# golang: GOPATH·~/go/bin 등 디렉터리가 있으면 그때만 PATH에 넣고, 없을 때만 go env
_golang_bins=()
if [[ -n ${GOPATH:-} ]]; then
  for _golang_p in ${(s.:.)GOPATH}; do
    [[ -n $_golang_p && -d "$_golang_p/bin" ]] && _golang_bins+=("$_golang_p/bin")
  done
fi
[[ -d "$HOME/go/bin" ]] && _golang_bins+=("$HOME/go/bin")
_golang_bins=(${(u)_golang_bins})
if (( $#_golang_bins )); then
  export PATH="${PATH}:${(j.:.)_golang_bins}"
elif command -v go &> /dev/null; then
  _golang_gp="$(go env GOPATH 2>/dev/null)"
  for _golang_p in ${(s.:.)_golang_gp}; do
    [[ -n $_golang_p && -d "$_golang_p/bin" ]] && export PATH="$PATH:$_golang_p/bin"
  done
  unset _golang_gp
fi
unset _golang_bins _golang_p

