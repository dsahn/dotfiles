fi

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
# fzf 키바인딩 커스터마이징
bindkey -r "^T"  # 기존 Ctrl+T 제거
bindkey "^F" fzf-file-widget  # Ctrl+F로 파일 선택
# fzf 자동완성 강제 활성화
export FZF_COMPLETION_TRIGGER='**'

