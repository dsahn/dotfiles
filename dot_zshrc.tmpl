# mise: 기본은 지연 로드(시작 시 mise 관련 source 없음). 첫 `mise` 호출 때 활성화.
# 항상 켜두려면 MISE_LAZY_LOAD=0 (~/.zshenv 등). 훅 방식은 MISE_USE_SHIMS=0.
if command -v mise &> /dev/null; then
  if [[ "${MISE_LAZY_LOAD:-1}" == "0" ]]; then
    if [[ "${MISE_USE_SHIMS:-1}" == "1" ]]; then
      _mise_cache="${XDG_CACHE_HOME:-$HOME/.cache}/mise-init-shims.zsh"
      _mise_activate_cmd=(mise activate zsh --shims)
    else
      _mise_cache="${XDG_CACHE_HOME:-$HOME/.cache}/mise-init-hook.zsh"
      _mise_activate_cmd=(mise activate zsh)
    fi
    if [[ ! -f "$_mise_cache" ]] || [[ "$(command -v mise)" -nt "$_mise_cache" ]]; then
      "${_mise_activate_cmd[@]}" > "$_mise_cache"
    fi
    source "$_mise_cache"
    unset _mise_cache _mise_activate_cmd
  else
    if [[ "${MISE_USE_SHIMS:-1}" == "1" ]]; then
      _mise_lazy_cache="${XDG_CACHE_HOME:-$HOME/.cache}/mise-init-shims.zsh"
      _mise_lazy_flags=(zsh --shims)
    else
      _mise_lazy_cache="${XDG_CACHE_HOME:-$HOME/.cache}/mise-init-hook.zsh"
      _mise_lazy_flags=(zsh)
    fi
    mise() {
      unset -f mise
      local _mbin
      _mbin="$(command -v mise)"
      if [[ ! -f "$_mise_lazy_cache" ]] || [[ "$_mbin" -nt "$_mise_lazy_cache" ]]; then
        "$_mbin" activate "${_mise_lazy_flags[@]}" > "$_mise_lazy_cache"
      fi
      source "$_mise_lazy_cache"
      mise "$@"
    }
    # 셸 띄운 뒤 shims/PATH만 켜고 싶을 때(명령 없이): mise_on
    mise_on() { mise --version >/dev/null; }
  fi
fi

