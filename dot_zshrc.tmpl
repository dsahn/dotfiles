alias vv='fd --type f --hidden --exclude .git | fzf-tmux -p --reverse | xargs nvim'
# preview alias
# alias prv="fd --type f --hidden --exclude .git | fzf --preview 'bat {1}' | xargs nvim"
alias prv="fzf --preview 'bat --style=numbers --color=always --line-range :500 {}' | xargs nvim"

_fzf_comprun() {
  local command=$1
  shift

  case "$command" in
    cd)           fd --type d | fzf "$@" --preview 'tree -C {} | head -200' ;;
    *)            fzf "$@" ;;
  esac
}

