-- Generated by chezmoi. Do not edit under ~/.config (overwritten on apply).
-- Set optional languages in chezmoi data, e.g. [data] nvim_languages = ["rust", "typescript"]
return {
  languages = {
{{- $langs := index . "nvim_languages" }}
{{- if $langs }}
{{- range $langs }}
    "{{ . }}",
{{- end }}
{{- end }}
  },
}
